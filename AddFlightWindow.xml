<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="AviationLogbook.UI.AddFlightWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="Add New Flight" Height="350" Width="400" Background="#F5F5F5">
	<Grid Margin="20">
		<StackPanel>
			<TextBlock Text="Add New Flight Log" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

			<UniformGrid Columns="2">
				<TextBlock Text="Origin (ICAO):" VerticalAlignment="Center" Margin="5"/>
				<TextBox x:Name="txtOrigin" Margin="5" Padding="3"/>

				<TextBlock Text="Destination (ICAO):" VerticalAlignment="Center" Margin="5"/>
				<TextBox x:Name="txtDestination" Margin="5" Padding="3"/>

				<TextBlock Text="Duration (Min):" VerticalAlignment="Center" Margin="5"/>
				<TextBox x:Name="txtDuration" Margin="5" Padding="3"/>

				<TextBlock Text="Date:" VerticalAlignment="Center" Margin="5"/>
				<DatePicker x:Name="dpDate" Margin="5"/>
			</UniformGrid>

			<Button x:Name="btnSave" Content="Save Flight" Margin="0,20,0,0"
                    Height="35" Background="#2196F3" Foreground="White" FontWeight="Bold"
                    Click="btnSave_Click"/>
		</StackPanel>
	</Grid>
</Window>